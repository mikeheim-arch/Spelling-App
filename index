<!-- RESULTS -->

<div class="card hidden" id="screen-results">
  <div style="text-align:center;">
    <div class="score-circle">
      <span class="score-num" id="res-score">0</span>
      <span class="score-den" id="res-denom">out of 0</span>
    </div>
    <h2 id="res-title" style="margin-bottom:6px;">Great job!</h2>
    <p class="sub" id="res-msg">Here is how you did:</p>
  </div>
  <div class="result-list" id="result-list"></div>
  <div class="results-btns">
    <button class="btn btn-yellow btn-full" id="retry-btn" onclick="retryMissed()">Practice Missed Words</button>
