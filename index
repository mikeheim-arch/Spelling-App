</div>

<script>
var words = [];
var wordIndex = 0;
var score = 0;
var results = [];
var mode = 'mic';
var recog = null;
var listening = false;
var heardText = '';

document.getElementById('word-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') addWord();
});

function addWord() {
  var val = document.getElementById('word-input').value.trim().toLowerCase();
  if (!val) return;
  if (words.indexOf(val) === -1) words.push(val);
  document.getElementById('word-input').value = '';
  document.getElementById('word-input').focus();
  renderChips();
}

function importList() {
  var text = document.getElementById('paste-box').value;
  var lines = text.split(/[\n,]+/);
  for (var i = 0; i < lines.length; i++) {
    var w = lines[i].trim().toLowerCase();
    if (w && words.indexOf(w) === -1) words.push(w);
  }
  document.getElementById('paste-box').value = '';
  renderChips();
}

function removeWord(i) {
  words.splice(i, 1);
  renderChips();
}

function renderChips() {
  var area = document.getElementById('chip-area');
  area.innerHTML = '';
  if (words.length === 0) {
    area.innerHTML = '<span class="none-msg">No words yet...</span>';
  } else {
    for (var i = 0; i < words.length; i++) {
      (function(idx) {
        var chip = document.createElement('div');
        chip.className = 'chip';
        chip.innerHTML = words[idx] + ' <span class="chip-x" onclick="removeWord(' + idx + ')">x</span>';
        area.appendChild(chip);
      })(i);
    }
  }
  document.getElementById('start-btn').disabled = words.length === 0;
}

function shuffle(arr) {
  var a = arr.slice();
  for (var i = a.length - 1; i > 0; i--) {
    var j = Math.floor(Math.random() * (i + 1));
    var tmp = a[i]; a[i] = a[j]; a[j] = tmp;
  }
  return a;
}

function startPractice() {
  if (words.length === 0) return;
  wordIndex = 0; score = 0; results = [];
  words = shuffle(words);
  show('screen-practice');
  hide('screen-setup');
  hide('screen-results');
  loadWord();
}

function loadWord() {
  var total = words.length;
  var pct = Math.round((wordIndex / total) * 100);
  document.getElementById('prog-fill').style.width = pct + '%';
  document.getElementById('prog-label').textContent = 'Word ' + (wordIndex + 1) + ' of ' + total;
  document.getElementById('word-num').textContent = 'Word #' + (wordIndex + 1);
  document.getElementById('feedback-area').innerHTML = '';
  hide('next-row');
  show('answer-area');
  resetMic();
  document.getElementById('type-input').value = '';
  setTimeout(speakWord, 600);
}

function speakWord() {
  var word = words[wordIndex];
  if (!word) return;
  window.speechSynthesis.cancel();
  var u = new SpeechSynthesisUtterance(word);
  u.rate = 0.8;
  u.onend = function() {
    if (mode === 'mic') {
      setTimeout(function() {
        setStatus('Now spell the word out loud!');
        setTimeout(startListening, 500);
      }, 400);
    }
  };
  window.speechSynthesis.speak(u);
}

function setMode(m) {
  mode = m;
  document.getElementById('tab-mic').className = 'toggle-btn' + (m === 'mic' ? ' on' : '');
  document.getElementById('tab-type').className = 'toggle-btn' + (m === 'type' ? ' on' : '');
  if (m === 'mic') {
    show('mic-area');
    hide('type-area');
  } else {
    hide('mic-area');
    show('type-area');
    setTimeout(function() { document.getElementById('type-input').focus(); }, 100);
  }
}

document.getElementById('type-input').addEventListener('keydown', function(e) {
  if (e.key === 'Enter') checkAnswer();
});

function startListening() {
  var SR = window.SpeechRecognition || window.webkitSpeechRecognition;
  if (!SR) {
    setStatus('Mic not supported. Please use Type It mode.');
    return;
  }
  if (listening) return;
  heardText = '';
  hide('mic-submit');
  recog = new SR();
  recog.continuous = false;
  recog.interimResults = true;
  recog.lang = 'en-US';
  recog.onresult = function(e) {
    var interim = '';
    for (var i = e.resultIndex; i < e.results.length; i++) {
      if (e.results[i].isFinal) {
        heardText = e.results[i][0].transcript.trim().toLowerCase().replace(/[^a-z]/g, '');
      } else {
        interim = e.results[i][0].transcript;
      }
    }
    var display = heardText || interim;
    if (display) setStatus('I heard: ' + display);
    if (heardText) {
      stopListening();
      show('mic-submit');
    }
  };
  recog.onerror = function(e) {
    stopListening();
    if (e.error === 'not-allowed') {
      setStatus('Mic blocked. Please use Type It mode.');
    } else if (e.error === 'no-speech') {
      setStatus('No speech heard. Tap mic to try again.');
    } else {
      setStatus('Mic error. Please use Type It mode.');
    }
  };
  recog.onend = function() { if (listening) stopListening(); };
  try {
    recog.start();
    listening = true;
    document.getElementById('mic-btn').className = 'mic-box on';
    document.getElementById('mic-lbl').textContent = 'Listening... spell it now!';
    setStatus('Go ahead, spell the word!');
  } catch(err) {
    setStatus('Could not start mic. Please use Type It mode.');
  }
}

function toggleMic() {
  if (listening) { stopListening(); return; }
  startListening();
}

function stopListening() {
  listening = false;
  if (recog) { try { recog.stop(); } catch(e) {} }
  document.getElementById('mic-btn').className = 'mic-box';
  document.getElementById('mic-lbl').textContent = 'Tap to spell again';
}

function resetMic() {
  stopListening();
  heardText = '';
  hide('mic-submit');
  setStatus('');
}

function setStatus(msg) {
  document.getElementById('mic-status').textContent = msg;
}

function checkAnswer() {
  var correct = words[wordIndex];
  var given = '';
  if (mode === 'mic') {
    given = heardText;
    if (!given) { setStatus('Nothing heard yet. Please try again.'); return; }
  } else {
    given = document.getElementById('type-input').value.trim().toLowerCase().replace(/[^a-z]/g, '');
    if (!given) return;
  }
  var isOk = given === correct;
  if (isOk) score++;
  results.push({ word: correct, given: given, ok: isOk });
  hide('answer-area');
  showFeedback(isOk, correct, given);
  show('next-row');
  var isLast = wordIndex === words.length - 1;
  document.getElementById('next-btn').textContent = isLast ? 'See My Score!' : 'Next Word';
}

var goodMsg = ['Amazing!','You nailed it!','Super spelling!','Fantastic!','Brilliant!','Correct!'];
var badMsg = ['Not quite - try again next time!','Good try! Keep going!','Almost! You will get it!','Keep practicing!'];

function rand(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

function showFeedback(isOk, correct, given) {
  var emoji = isOk ? '&#127881;' : '&#128170;';
  var msg = isOk ? rand(goodMsg) : rand(badMsg);
  var html = '<div class="feedback ' + (isOk ? 'ok' : 'no') + '">';
  html += '<span class="fb-emoji">' + emoji + '</span>';
  html += '<div class="fb-msg">' + msg + '</div>';
  if (isOk) {
    html += '<div class="fb-word">You spelled <strong>' + correct + '</strong> correctly!</div>';
  } else {
    html += '<div class="fb-word">The correct spelling is:<br><strong>' + correct + '</strong></div>';
  }
  html += '</div>';
  document.getElementById('feedback-area').innerHTML = html;
  setTimeout(function() {
    var text = isOk ? 'Great job! ' + correct + ' is correct!' : 'The correct spelling is ' + correct.split('').join(' ');
    var u = new SpeechSynthesisUtterance(text);
    u.rate = 0.9;
    window.speechSynthesis.speak(u);
  }, 300);
}

function nextWord() {
  wordIndex++;
  if (wordIndex >= words.length) {
    showResults();
  } else {
    loadWord();
  }
}

function showResults() {
  hide('screen-practice');
  show('screen-results');
  document.getElementById('res-score').textContent = score;
  document.getElementById('res-denom').textContent = 'out of ' + words.length;
  var pct = score / words.length;
  var title, msg;
  if (pct === 1)       { title = 'Perfect Score!'; msg = 'Every word correct - amazing!'; }
  else if (pct >= 0.8) { title = 'Great Job!'; msg = 'Almost perfect - nice work!'; }
  else if (pct >= 0.6) { title = 'Nice Work!'; msg = 'Good effort - keep practicing!'; }
  else                 { title = 'Keep Going!'; msg = 'Practice makes perfect!'; }
  document.getElementById('res-title').textContent = title;
  document.getElementById('res-msg').textContent = msg;
  var html = '';
  for (var i = 0; i < results.length; i++) {
    var r = results[i];
    html += '<div class="result-row ' + (r.ok ? 'ok' : 'no') + '">';
    html += '<span>' + (r.ok ? 'OK' : 'X') + '</span>';
    html += '<span class="r-word">' + r.word + '</span>';
    if (!r.ok) html += '<span class="r-given">you said: ' + r.given + '</span>';
    html += '</div>';
  }
  document.getElementById('result-list').innerHTML = html;
  var missed = results.filter(function(r) { return !r.ok; });
  document.getElementById('retry-btn').style.display = missed.length > 0 ? '' : 'none';
}

function retryMissed() {
  words = results.filter(function(r) { return !r.ok; }).map(function(r) { return r.word; });
  startPractice();
}

function restartAll() {
  wordIndex = 0; score = 0; results = [];
  words = shuffle(words);
  show('screen-practice');
  hide('screen-results');
  loadWord();
}

function newList() {
  words = []; wordIndex = 0; score = 0; results = [];
  renderChips();
  show('screen-setup');
  hide('screen-practice');
  hide('screen-results');
}

function show(id) {
  document.getElementById(id).classList.remove('hidden');
}
function hide(id) {
  document.getElementById(id).classList.add('hidden');
}
</script>

</body>
